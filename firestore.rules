rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ─────────────────────────────────────────────────────────────────
    // Anyone logged in can read profiles; users can only write their own
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;
    }

    // ── Posts (global feed) ───────────────────────────────────────────────────
    // All authenticated users can read and create posts
    // Only post author can delete their post
    match /posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.authorId == request.auth.uid;
      allow update: if request.auth != null; // needed for reactionCounts increment
      allow delete: if request.auth.uid == resource.data.authorId;

      // Reactions — each user manages their own reaction doc
      match /reactions/{userId} {
        allow read: if request.auth != null;
        allow write: if request.auth.uid == userId;
      }

      // Comments — anyone logged in can read/create; author can delete
      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
                      && request.resource.data.authorId == request.auth.uid;
        allow delete: if request.auth.uid == resource.data.authorId;
      }
    }

    // ── Mood check-ins (private per user) ─────────────────────────────────────
    match /mood_checkins/{userId}/checkins/{checkinId} {
      allow read, write: if request.auth.uid == userId;
    }

    // ── Soul conversations (private per user) ─────────────────────────────────
    match /soul_conversations/{userId}/messages/{messageId} {
      allow read, write: if request.auth.uid == userId;
    }

    // ── Communities ───────────────────────────────────────────────────────────
    match /communities/{communityId} {
      allow read: if request.auth != null;
      allow write: if false; // managed via Admin SDK / seeded directly

      match /posts/{postId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
      }
    }
  }
}
