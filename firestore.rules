rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ──────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId;

      // Followers sub-collection: target user's doc
      match /followers/{followerId} {
        allow read: if request.auth != null;
        allow write: if request.auth.uid == followerId;
      }
      // Following sub-collection: current user's doc
      match /following/{followingId} {
        allow read: if request.auth != null;
        allow write: if request.auth.uid == userId;
      }
    }

    // ── Posts ──────────────────────────────────────────────────────────────────
    match /posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow delete: if request.auth.uid == resource.data.authorId;
      allow update: if request.auth != null;

      match /reactions/{userId} {
        allow read, write: if request.auth.uid == userId;
      }
      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow delete: if request.auth.uid == resource.data.authorId;
      }
      match /pollVotes/{userId} {
        allow read: if request.auth != null;
        allow create: if request.auth.uid == userId;
      }
    }

    // ── Mood check-ins ─────────────────────────────────────────────────────────
    match /mood_checkins/{userId}/checkins/{checkinId} {
      allow read, write: if request.auth.uid == userId;
    }

    // ── Soul conversations ─────────────────────────────────────────────────────
    match /soul_conversations/{userId}/messages/{messageId} {
      allow read, write: if request.auth.uid == userId;
    }

    // ── Stories ────────────────────────────────────────────────────────────────
    match /stories/{storyId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update: if request.auth != null; // for marking viewed
      allow delete: if request.auth.uid == resource.data.userId;
    }

    // ── Notifications ──────────────────────────────────────────────────────────
    match /notifications/{userId}/items/{notifId} {
      allow read, write: if request.auth.uid == userId;
      // Allow other authenticated users to create notifications for this user
      allow create: if request.auth != null;
    }

    // ── Communities ────────────────────────────────────────────────────────────
    match /communities/{communityId} {
      allow read: if request.auth != null;
      allow write: if false; // Admin SDK only for community metadata

      match /events/{eventId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow update: if request.auth != null; // for RSVP
        allow delete: if request.auth.uid == resource.data.organizerId;
      }
    }
  }
}
